# LM Studio local server (Developer tab → Start server)
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_API_KEY=lm-studio

# Leave empty to auto-detect the first loaded model from LM Studio
LMSTUDIO_MODEL=

# MCP HTTP server (start with: python mcp/server.py)
MCP_HOST=127.0.0.1
MCP_PORT=8000
# Optional override. If unset, URL is built from MCP_HOST and MCP_PORT.
# MCP_URL=http://127.0.0.1:8000/mcp

# Playwright MCP (optional). Install Chromium first, then start the server:
# npx playwright install chromium
# npx @playwright/mcp@latest --port 8931 --headless --no-sandbox --allowed-hosts *
# PLAYWRIGHT_MCP_URL=http://127.0.0.1:8931/mcp

# Optional fixed location (used by get_local_coordinates)
# Example for Arad, Romania:
# LOCAL_LATITUDE=46.1866
# LOCAL_LONGITUDE=21.3123
LOCAL_LATITUDE=
LOCAL_LONGITUDE=
