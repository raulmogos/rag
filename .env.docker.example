# Copy to .env in the project root for docker compose:
# cp .env.docker.example .env

# LM Studio runs on the host machine (Developer tab -> Start server)
LMSTUDIO_BASE_URL=http://host.docker.internal:1234/v1
LMSTUDIO_API_KEY=lm-studio
LMSTUDIO_MODEL=

# Host ports exposed by docker compose
MCP_PORT=8000
API_PORT=8001
FRONTEND_PORT=8080
PLAYWRIGHT_MCP_PORT=8931

# Playwright MCP (browser automation). Leave empty to disable locally.
# Docker compose sets this automatically for the api service.
PLAYWRIGHT_MCP_URL=http://127.0.0.1:8931/mcp

# Optional fixed location for weather/coordinates tools
LOCAL_LATITUDE=
LOCAL_LONGITUDE=

# Frontend origin allowed by the API CORS middleware
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
